# Copy to .env next to docker-compose.yml to override the dev defaults.
# This file documents variable NAMES with example values only — never commit
# a real .env or real credentials (.gitignore already excludes .env).

# PostgreSQL password for the compose `db` service. The compose file ships a
# labeled dev-only default; override it for anything beyond local dev.
POSTGRES_PASSWORD=change-me

# SMTP relay for verification email. Default is the bundled Mailpit sink
# (host `mailpit`, port 1025, UI on http://localhost:8025).
# For the DataArt relay, set:
SMTP_HOST=relay1.dataart.com
SMTP_PORT=25
# Credentials if the relay requires them (leave unset for Mailpit):
# SMTP_USER=
# SMTP_PASS=

# Base URL used to build verification links in outgoing email.
APP_BASE_URL=http://localhost:8080
